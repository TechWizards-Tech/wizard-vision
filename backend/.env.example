# Ambiente
NODE_ENV=development
PORT=3333

# Banco de Dados (substitua pela sua connection string do Supabase ou Neon.tech)
DATABASE_URL="postgresql://usuario:senha@host:5432/atletatrack?schema=public"

# JWT
JWT_SECRET=seu_secret_super_seguro_aqui_mude_em_producao
JWT_EXPIRES_IN=24h

# Segurança e Criptografia (Chave simétrica de 32 bytes em formato hex para AES-256-GCM)
ENCRYPTION_KEY=insira_uma_chave_hexadecimal_de_64_caracteres_aqui

# CORS - URL do frontend
CORS_ORIGIN=http://localhost:5173
